{
  "name": "zapdev",
  "version": "0.7.0",
  "description": "Fast, performant and lightweight git chores and dev tools using your terminal and your own local LLM.",
  "type": "module",
  "bin": {
    "zapdev": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "git",
    "cli",
    "commit",
    "conventional-commits",
    "ollama",
    "llm",
    "ai"
  ],
  "author": "Matthieu Vagnon <hi@mvagnon.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mvagnon/zapdev.git"
  },
  "homepage": "https://github.com/mvagnon/zapdev#readme",
  "bugs": {
    "url": "https://github.com/mvagnon/zapdev/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "zapdev": "npm run build && node dist/index.js",
    "build": "esbuild src/cli.ts --bundle --platform=node --format=esm --target=node20 --loader:.md=text --outfile=dist/cli.js && esbuild src/index.ts --platform=node --format=esm --target=node20 --outfile=dist/index.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepack": "npm run build"
  },
  "devDependencies": {
    "@clack/prompts": "^1.6.0",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^2.0.0",
    "@eslint/markdown": "^8.0.2",
    "@types/node": "^26.1.1",
    "citty": "^0.2.2",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "jiti": "^2.7.0",
    "tinyexec": "^1.2.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  }
}
